# Generate a random secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Google OAuth (optional — leave blank for local dev mode with auto-login)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:8000/auth/google/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
